class Solution:
    def segregate(self, head):
        if not head or not head.next:
            return head

        zero_head = Node(-1)
        one_head = Node(-1)
        two_head = Node(-1)

        zero, one, two = zero_head, one_head, two_head
        curr = head

        while curr:
            next_node = curr.next
            curr.next = None
            if curr.data == 0:
                zero.next = curr
                zero = curr
            elif curr.data == 1:
                one.next = curr
                one = curr
            else:
                two.next = curr
                two = curr
            curr = next_node

        zero.next = one_head.next if one_head.next else two_head.next
        one.next = two_head.next
        return zero_head.next