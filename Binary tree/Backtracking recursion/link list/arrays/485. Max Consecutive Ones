class Solution(object):
    def findMaxConsecutiveOnes(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        count = 0
        maxi = 0
        i = 0
        while i < len(nums):
            if nums[i] == 1:
                count += 1
                maxi = max(maxi, count)
            else:
                count = 0 
            i += 1    
            

        return maxi