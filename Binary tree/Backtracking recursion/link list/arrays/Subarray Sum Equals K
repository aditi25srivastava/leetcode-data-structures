class Solution:
    def subarraySum(self, nums: List[int], k: int) -> int:
        freq = {0:1}
        pre_Sum = 0
        ans = 0
        for num in nums:
            pre_Sum += num
            ans += freq.get(pre_Sum - k, 0)
            freq[pre_Sum] = freq.get(pre_Sum, 0) + 1
        return ans    
    
        